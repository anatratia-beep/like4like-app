# ==== Serveur ====
PORT=3000
JWT_SECRET=change-moi-avec-une-longue-chaine-aleatoire
BASE_URL=https://ton-domaine-ou-ip-publique.mg

# ==== Compte admin cree automatiquement au premier demarrage ====
ADMIN_TELEPHONE=0340000000
ADMIN_PASSWORD=change-moi

# ==== Regles economiques (modifiables aussi depuis /admin/settings une fois lance) ====
ARIARY_PAR_JETON=10
JETONS_PAR_PUBLICATION=100
POINTS_PAR_PUBLICATION=10
ARIARY_PAR_POINT=50
POINTS_PAR_INTERACTION=1
DELAI_VALIDATION_HEURES=48

# ==== MVola (https://developer.mvola.mg/devportal/) ====
# A obtenir en creant un compte "marchand" sur le portail developpeur MVola.
# IMPORTANT : les noms exacts de champs/endpoints doivent etre reverifies sur
# le devportal au moment de l'integration, l'API peut evoluer.
MVOLA_ENV=sandbox
MVOLA_CONSUMER_KEY=
MVOLA_CONSUMER_SECRET=
MVOLA_PARTNER_NAME=NomDeTonEtablissement
MVOLA_PARTNER_MSISDN=0343500004
MVOLA_SANDBOX_BASE_URL=https://devapi.mvola.mg
MVOLA_PROD_BASE_URL=https://api.mvola.mg

# ==== Orange Money / Airtel Money ====
# Non implementes automatiquement : chaque operateur a sa propre API et
# necessite un compte marchand distinct. Voir README.md section "Paiements".
ORANGE_MONEY_MERCHANT_KEY=
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
